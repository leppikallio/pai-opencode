node_modules/

# Runtime session data (never commit)
.opencode/MEMORY/*
!.opencode/MEMORY/README.md

# Runtime session data (never commit)
MEMORY/**

# Plugin debug logs
.opencode/plugins/*.log

# Local session transcripts (never commit)
session-ses_*.md

# Temporary planning/review documents (never commit)
docs/plans/
docs/reviews/

# Private and temporary OpenCode repository content (never commit)
.opencode/Plans/
.opencode/History/
.opencode/BACKUPS/
.opencode/skills/PAI/USER/
.opencode/skills/**/Scratchpad/
.opencode/skills/**/State/
.opencode/skills/**/Reports/
.opencode/**/__pycache__/
.opencode/**/state.json

# Underscore-prefixed agent drafts/variants
.opencode/agents/_*.md

# Backup folders created by converter/migration tools
.opencode.backup-*/
.scratchpad/

# Local config/state artifacts (never commit)
.opencode/config/
.opencode/skills/PAIUpgrade/State/

# macOS metadata
.DS_Store

# draw.io temp files
**/.$*.drawio.dtmp

# Local backup artifacts (never commit)
Components_backup/
opencode.json.tui-migration.bak

# Git worktrees (local only)
.worktrees/

# nWave generated outputs
.opencode/agents/nw-*.md
.opencode/commands/nw/
.opencode/skills/nwave/
